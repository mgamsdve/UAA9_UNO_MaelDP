<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:nsd="https://structorizer.fisch.lu" version="3.32-34" preRepeat="until " postFor="to" preReturn="return" postForIn="in" preWhile="while " output="OUTPUT" input="INPUT" preFor="for" preExit="exit" preLeave="leave" ignoreCase="true" preThrow="throw" preForIn="foreach" stepFor="by" namespace="" author="mgams" created="2026-03-03" changedby="mgams" changed="2026-03-03" origin="Structorizer 3.32-34" text="&#34;InitialiserCartes&#34;" comment="" color="ffffff" type="program" style="nice">
	<children>
		<instruction text="&#34;JeuCartes = new string[48]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;indexCarte = 0&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;string[] couleurs = { &#34;&#34;Rouge&#34;&#34;, &#34;&#34;Bleu&#34;&#34;, &#34;&#34;Vert&#34;&#34;, &#34;&#34;Jaune&#34;&#34; }&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<for text="&#34;foreach couleur in couleurs&#34;" comment="" counterVar="couleur" startValue="" stepConst="" style="TRAVERSAL" insep="in" color="ffffff" disabled="0">
			<qFor>
				<for text="&#34;for numeroCarte=0 to 9; numeroCarte++;&#34;" comment="" counterVar="dummy_counter" startValue="numeroCarte=0" endValue="9; numeroCarte++;" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
					<qFor>
						<instruction text="&#34;JeuCartes[indexCarte] =  couleur + &#34;&#34; &#34;&#34; + numeroCarte&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;indexCarte++;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFor>
				</for>
				<instruction text="&#34;jeuCartes[indexCarte] = &#34;&#34;+2 &#34;&#34;+ couleur&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;indexCarte++;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;jeuCartes[indexCarte] = &#34;&#34;Passe ton tour&#34;&#34;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;indexCarte++;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
			</qFor>
		</for>
		<instruction text="&#34;jeuCartes[indexCarte] = &#34;&#34;+4 &#34;&#34;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;indexCarte++;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;jeuCartes[indexCarte] = &#34;&#34;Changement de couleur&#34;&#34;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;indexCarte++;&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
	</children>
</root>
<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:nsd="https://structorizer.fisch.lu" version="3.32-34" preRepeat="until " postFor="to" preReturn="return" postForIn="in" preWhile="while " output="OUTPUT" input="INPUT" preFor="for" preExit="exit" preLeave="leave" ignoreCase="true" preThrow="throw" preForIn="foreach" stepFor="by" author="mgams" created="2026-03-26" changedby="mgams" changed="2026-03-26" origin="Structorizer 3.32-34" text="&#34;EstCarteJouable&#34;" comment="" color="ffffff" type="program" style="nice">
	<children>
		<instruction text="&#34;estJouable = false&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;couleurCourante = carteCourante.Split(' ')[0]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;valeurCourante = carteCourante.Split(' ')[1]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;couleurTable = carteTable.Split(' ')[0]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;valeurTable = carteTable.Split(' ')[1]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
		<alternative text="&#34;if carteCourante = &#34;&#34;+4&#34;&#34; OR carteCourante = &#34;&#34;Changement de couleur&#34;&#34;&#34;" comment="&#34;&#34;" color="ffffff" branch_colors="," disabled="0">
			<qTrue>
				<instruction text="&#34;estJouable = true&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
			</qTrue>
			<qFalse>
				<alternative text="&#34;if couleurCourante = couleurTable OR valeurCourante = valeurTable&#34;" comment="&#34;&#34;" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<instruction text="&#34;estJouable = true&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qTrue>
					<qFalse color="ffffff">
					</qFalse>
				</alternative>
			</qFalse>
		</alternative>
		<instruction text="&#34;return estJouable&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
	</children>
</root>
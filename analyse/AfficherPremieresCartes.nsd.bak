<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:nsd="https://structorizer.fisch.lu" version="3.32-34" text="AfficherPremieresCartes" type="program" style="nice">
	<children>

		<instruction text="OUTPUT titre"></instruction>

		<instruction text="limite = MIN(nombre, jeuCartes.length)"></instruction>

		<for text="for i = 0 to limite - 1 ; i++ ;" counterVar="i" startValue="0" endValue="limite - 1" stepConst="1" style="FREETEXT">
			<qFor>
				<instruction text="OUTPUT (i + 1) + &quot;. &quot; + jeuCartes[i]"></instruction>
			</qFor>
		</for>

	</children>
</root>